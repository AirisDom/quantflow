{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=quantflow;Username=postgres;Password=postgres"
  },
  "SignalService": {
    "Address": "http://localhost:50051",
    "MaxRetryAttempts": 5,
    "InitialBackoffMs": 100,
    "MaxBackoffMs": 5000,
    "BackoffMultiplier": 2.0,
    "DeadlineMs": 30000,
    "IdleTimeoutSeconds": 60,
    "KeepAlivePingDelaySeconds": 30,
    "KeepAlivePingTimeoutSeconds": 10
  },
  "ExecutionService": {
    "Address": "http://localhost:50052",
    "MaxRetryAttempts": 3,
    "InitialBackoffMs": 50,
    "MaxBackoffMs": 1000,
    "BackoffMultiplier": 1.5,
    "DeadlineMs": 5000,
    "IdleTimeoutSeconds": 60,
    "KeepAlivePingDelaySeconds": 30,
    "KeepAlivePingTimeoutSeconds": 10,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerResetTimeMs": 30000
  }
}
