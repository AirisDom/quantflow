# QuantFlow Environment Configuration
# Copy this file to .env and fill in the appropriate values for your environment.
# NEVER commit your .env file to version control.

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=quantflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# C# Orchestrator Configuration
# =============================================================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Serilog logging level (Verbose, Debug, Information, Warning, Error, Fatal)
SERILOG_MINIMUM_LEVEL=Information

# Database connection string (uses the PostgreSQL variables above)
# Format: Host=<host>;Database=<db>;Username=<user>;Password=<password>
ORCHESTRATOR_DB_CONNECTION_STRING=Host=postgres;Database=quantflow;Username=postgres;Password=changeme_in_production

# Signal service gRPC endpoint
SIGNAL_SERVICE_ADDRESS=http://signal_engine:50051

# Execution service gRPC endpoint
EXECUTION_SERVICE_ADDRESS=http://execution_layer:50052

# Price ticker interval in milliseconds
PRICE_TICKER_INTERVAL_MS=1000

# Initial cash balance for the portfolio
PORTFOLIO_INITIAL_CASH=100000

# Risk management limits (as decimal values, e.g., 0.05 = 5%)
RISK_MAX_DRAWDOWN_PERCENT=0.05
RISK_MAX_POSITION_SIZE_PERCENT=0.10
RISK_MAX_EXPOSURE_PERCENT=0.80
RISK_MIN_ORDER_VALUE=10

# =============================================================================
# Python Signal Engine Configuration
# =============================================================================
SIGNAL_ENGINE_PORT=50051
SIGNAL_ENGINE_HEALTH_PORT=8080
SIGNAL_ENGINE_WINDOW_SIZE=20
SIGNAL_ENGINE_THRESHOLD=0.02
SIGNAL_ENGINE_LOG_LEVEL=INFO

# =============================================================================
# Rust Execution Layer Configuration
# =============================================================================
EXECUTION_SERVICE_PORT=50052
EXECUTION_HEALTH_PORT=8081
EXECUTION_MIN_LATENCY_MS=10
EXECUTION_MAX_LATENCY_MS=50
RUST_LOG=info
